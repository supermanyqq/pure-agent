{
  "name": "@pure-agent/cli",
  "version": "0.1.0",
  "description": "Interactive terminal AI agent powered by DeepSeek.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/supermanyqq/pure-agent.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/supermanyqq/pure-agent/issues"
  },
  "homepage": "https://github.com/supermanyqq/pure-agent#readme",
  "keywords": ["agent", "ai", "chat", "cli", "deepseek", "llm"],
  "bin": {
    "pure-agent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm --filter @pure-agent/core run build && pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@pure-agent/core": "^0.1.0",
    "ink": "^6.6.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  }
}
